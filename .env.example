# Discord bot token (from Discord Developer Portal)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Channel ID for the bridged chat (Discord <-> Minecraft)
CHANNEL_ID=123456789

# Webhook URL for the same channel as CHANNEL_ID (used to send MC messages with player avatars)
WEBHOOK_URL=YOUR_WEBHOOK_URL_HERE

# Absolute path to the Minecraft server directory (where server.jar and logs/ live)
# Defaults to the current working directory if not set
SERVER_DIR=/path/to/minecraft/server

# RCON settings must match your server.properties
# Enable RCON in server.properties: enable-rcon=true
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=YOUR_RCON_PASSWORD_HERE

# Feature flags. Set to false to disable
ENABLE_COMMAND_EXECUTION=true
ENABLE_COMMAND_LOGGING=true  # Forwards in-game command results to the admin channel. Requires ADMIN_CHANNEL_ID.
ENABLE_WHITELIST=true
ENABLE_SEED=false  # Exposes the world seed, so keep it disabled if you don't want players knowing the seed.

# Admin channel. Used for !mc, !restart, and log alerts (WARN / "Can't keep up" lines)
# Required if ENABLE_COMMAND_EXECUTION=true or RESTART_COMMAND is set
ADMIN_CHANNEL_ID=123456789

# Required only if ENABLE_WHITELIST=true
WHITELIST_CHANNEL_ID=123456789

